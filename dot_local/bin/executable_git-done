#!/usr/bin/env bash
set -euo pipefail

if ! default=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||'); then
  echo "error: origin/HEAD is not set. Run: git remote set-head origin -a" >&2
  exit 1
fi

git switch "$default"
git pull -p
git branch -vv | sed 's/^[*+] /  /' | grep ': gone]' | awk '{print $1}' | xargs -r git branch -d
